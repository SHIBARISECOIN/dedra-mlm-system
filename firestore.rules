rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 여부 확인
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // 보조계정 여부 확인 (customToken uid: 'subadmin_...')
    function isSubAdmin() {
      return request.auth != null &&
        request.auth.uid.matches('subadmin_.+') &&
        request.auth.token.get('role', '') == 'subadmin';
    }

    // 관리자 또는 보조계정
    function isAdminOrSubAdmin() {
      return isAdmin() || isSubAdmin();
    }

    // 로그인 여부 확인
    function isActiveUser() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', '') == 'active';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /events/{docId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.auth.uid == userId;
      allow update: if isLoggedIn() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'rank', 'status', 'totalInvest', 'totalEarnings'])) ||
        isAdminOrSubAdmin()
      );
      allow delete: if isAdminOrSubAdmin();
    }

    // transactions: 본인 또는 관리자/보조계정
    match /transactions/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow create: if isAdminOrSubAdmin() || (isLoggedIn() && 
                    request.resource.data.userId == request.auth.uid &&
                    (request.resource.data.type != 'withdrawal' || 
                      (request.resource.data.get('amountUsdt', 0) >= 50 && 
                       exists(/databases/$(database)/documents/wallets/$(request.auth.uid)) &&
                       get(/databases/$(database)/documents/wallets/$(request.auth.uid)).data.get('bonusBalance', 0) >= request.resource.data.get('amountUsdt', 0))));
      allow update, delete: if isAdminOrSubAdmin();
    }

    // investments: 본인 또는 관리자/보조계정
    match /investments/{docId} {
      allow read: if isLoggedIn();
      allow create: if isAdminOrSubAdmin();
      allow update, delete: if isAdminOrSubAdmin();
    }

    // wallets: 본인 또는 관리자/보조계정
    match /wallets/{userId} {
      allow read: if isLoggedIn();
      allow create: if isAdminOrSubAdmin() || (
        isLoggedIn() && request.auth.uid == userId &&
        request.resource.data.get('usdtBalance', 0) == 0 &&
        request.resource.data.get('dedraBalance', 0) == 0 &&
        request.resource.data.get('bonusBalance', 0) == 0
      );
      allow update: if isAdminOrSubAdmin();
      allow delete: if isAdminOrSubAdmin();
    }

    match /gamelogs/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow create: if isLoggedIn();
      allow update, delete: if isAdminOrSubAdmin();
    }

    match /bonuses/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    match /announcements/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    match /tickets/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow delete: if isAdminOrSubAdmin();
    }

    match /settings/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    match /products/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    match /notifications/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || resource.data.targetAll == true || isAdminOrSubAdmin());
      allow create: if isAdminOrSubAdmin();
      allow update: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow delete: if isAdminOrSubAdmin();
    }

    match /broadcasts/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /auditLogs/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /centers/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /news/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    match /scheduledBroadcasts/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /autoRules/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /settlements/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /rateHistory/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /subAdmins/{docId} {
      allow read, write: if isAdmin();
    }

    match /memberEditLogs/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /pendingSettlements/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /fcmTokens/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    match /chats/{roomId} {
      allow read, write: if isLoggedIn();
    }
    
    match /chats/{roomId}/messages/{messageId} {
      allow read, write: if isLoggedIn();
    }

    match /page_views/{docId} {
      allow read: if isAdminOrSubAdmin();
      allow create: if isLoggedIn();
    }
  }
}
