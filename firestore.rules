rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 여부 확인
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 보조계정 여부 확인 (customToken uid: 'subadmin_...')
    function isSubAdmin() {
      return request.auth != null &&
        request.auth.uid.matches('subadmin_.+') &&
        request.auth.token.role == 'subadmin';
    }

    // 관리자 또는 보조계정
    function isAdminOrSubAdmin() {
      return isAdmin() || isSubAdmin();
    }

    // 로그인 여부 확인
    function isLoggedIn() {
      return request.auth != null;
    }

    // users: 본인 또는 관리자/보조계정
    match /users/{userId} {
      allow read: if isLoggedIn() && (request.auth.uid == userId || isAdminOrSubAdmin());
      allow write: if isLoggedIn() && (request.auth.uid == userId || isAdminOrSubAdmin());
    }

    // transactions: 본인 또는 관리자/보조계정
    match /transactions/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow create: if isLoggedIn();
      allow update, delete: if isAdminOrSubAdmin();
    }

    // investments: 본인 또는 관리자/보조계정
    match /investments/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow create: if isLoggedIn();
      allow update, delete: if isAdminOrSubAdmin();
    }

    // wallets: 본인 또는 관리자/보조계정
    match /wallets/{userId} {
      allow read, write: if isLoggedIn() && (request.auth.uid == userId || isAdminOrSubAdmin());
    }

    // gamelogs: 본인 쓰기, 관리자/보조계정 읽기/쓰기
    match /gamelogs/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow create: if isLoggedIn();
      allow update, delete: if isAdminOrSubAdmin();
    }

    // bonuses: 본인 또는 관리자/보조계정
    match /bonuses/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow write: if isAdminOrSubAdmin();
    }

    // announcements: 모든 로그인 유저 읽기, 관리자/보조계정 쓰기
    match /announcements/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    // tickets (1:1 문의): 본인 또는 관리자/보조계정
    match /tickets/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow delete: if isAdminOrSubAdmin();
    }

    // settings: 로그인 유저 읽기, 관리자/보조계정 쓰기
    match /settings/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    // products: 모든 로그인 유저 읽기, 관리자/보조계정 쓰기
    match /products/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    // notifications: 본인 또는 관리자/보조계정
    match /notifications/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || resource.data.targetAll == true || isAdminOrSubAdmin());
      allow create: if isAdminOrSubAdmin();
      allow update: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdminOrSubAdmin());
      allow delete: if isAdminOrSubAdmin();
    }

    // broadcasts: 관리자/보조계정만
    match /broadcasts/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // auditLogs: 관리자/보조계정만
    match /auditLogs/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // centers: 관리자/보조계정만
    match /centers/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // news: 모든 로그인 유저 읽기, 관리자/보조계정 쓰기
    match /news/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdminOrSubAdmin();
    }

    // scheduledBroadcasts: 관리자/보조계정만
    match /scheduledBroadcasts/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // autoRules (자동 알림 규칙): 관리자/보조계정만
    match /autoRules/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // settlements (일일 ROI 정산): 관리자/보조계정만
    match /settlements/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // rateHistory (DDRA 시세 이력): 관리자/보조계정만
    match /rateHistory/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // subAdmins (보조계정): 관리자만 (보조계정은 접근 불가)
    match /subAdmins/{docId} {
      allow read, write: if isAdmin();
    }

    // memberEditLogs (회원 자산 변경 이력): 관리자/보조계정만
    match /memberEditLogs/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // pendingSettlements: 관리자/보조계정만
    match /pendingSettlements/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // fcmTokens: 관리자/보조계정만
    match /fcmTokens/{docId} {
      allow read, write: if isAdminOrSubAdmin();
    }

    // chats: 그룹 및 1:1 채팅방 메타데이터
    match /chats/{roomId} {
      allow read, write: if isLoggedIn();
    }
    
    // chats: 그룹 채팅 메시지 (로그인한 모든 유저가 읽기/쓰기 가능)
    match /chats/{roomId}/messages/{messageId} {
      allow read, write: if isLoggedIn();
    }
  }
}

